<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LDAP 서버 설정 폼 확장 - Liferay 스타일 UI -->
    <record id="view_ldap_installer_form_inherit" model="ir.ui.view">
        <field name="name">res.company.ldap.form.inherit.polyon</field>
        <field name="model">res.company.ldap</field>
        <field name="inherit_id" ref="auth_ldap.view_ldap_installer_form"/>
        <field name="arch" type="xml">
            <!-- sequence 필드 숨기기 -->
            <xpath expr="//field[@name='sequence']" position="replace"/>

            <!-- 포트 번호 천단위 구분자 제거 -->
            <xpath expr="//field[@name='ldap_server_port']" position="attributes">
                <attribute name="options">{'format': false}</attribute>
            </xpath>

            <!-- user 필드 옵션 설정 (생성/열기 비활성화) -->
            <xpath expr="//field[@name='user']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
            </xpath>

            <!-- 헤더에 버튼 추가 -->
            <xpath expr="//header/button[@name='test_ldap_connection']" position="before">
                <button string="Back to List"
                        type="action"
                        name="%(auth_ldap.action_ldap_installer)d"
                        class="btn-secondary"
                        icon="fa-arrow-left"/>
            </xpath>
            <xpath expr="//header/button[@name='test_ldap_connection']" position="after">
                <button name="action_test_ldap_users"
                        string="Test LDAP Users"
                        type="object"
                        class="btn-secondary"
                        icon="fa-users"/>
                <button name="action_test_ldap_groups"
                        string="Test LDAP Groups"
                        type="object"
                        class="btn-secondary"
                        icon="fa-users"/>
                <button name="action_open_sync_wizard"
                        string="Sync Users &amp; Groups"
                        type="object"
                        class="btn-secondary"
                        invisible="not sync_groups"
                        icon="fa-refresh"/>
            </xpath>

            <!-- Liferay 스타일 Users & Groups 섹션 -->
            <xpath expr="//sheet/group" position="after">

                <!-- ========================================== -->
                <!-- Users & Groups (메인 타이틀)               -->
                <!-- ========================================== -->
                <div class="o_form_label" style="font-size: 1.5em; font-weight: bold; margin: 20px 0 10px 0;">
                    Users &amp; Groups
                </div>

                <!-- ========================================== -->
                <!-- USERS 섹션                                 -->
                <!-- ========================================== -->
                <separator string="USERS"/>

                <group col="1">
                    <label for="users_dn"/>
                    <field name="users_dn" nolabel="1" placeholder="OU=Users,DC=company,DC=com"/>
                </group>

                <!-- SEARCH 서브섹션 -->
                <separator string="SEARCH"/>
                <group col="1">
                    <label for="auth_search_filter"/>
                    <field name="auth_search_filter" widget="text" nolabel="1" placeholder="(&amp;(objectClass=person)(userPrincipalName=@email_address@))"/>
                    <label for="user_search_filter"/>
                    <field name="user_search_filter" widget="text" nolabel="1" placeholder="(&amp;(objectClass=person)(!(isCriticalSystemObject=TRUE))(!(userPrincipalName=*sys@*)))"/>
                </group>

                <!-- USER MAPPING 서브섹션 -->
                <separator string="USER MAPPING"/>
                <group>
                    <group>
                        <label for="ldap_attr_login"/>
                        <field name="ldap_attr_login" nolabel="1" placeholder="sAMAccountName"/>
                        <label for="ldap_attr_email"/>
                        <field name="ldap_attr_email" nolabel="1" placeholder="userPrincipalName"/>
                        <label for="ldap_attr_firstname"/>
                        <field name="ldap_attr_firstname" nolabel="1" placeholder="givenName"/>
                        <label for="ldap_attr_middlename"/>
                        <field name="ldap_attr_middlename" nolabel="1" placeholder="middleName"/>
                    </group>
                    <group>
                        <label for="ldap_attr_lastname"/>
                        <field name="ldap_attr_lastname" nolabel="1" placeholder="sn"/>
                        <label for="ldap_attr_fullname"/>
                        <field name="ldap_attr_fullname" nolabel="1" placeholder="displayName"/>
                        <label for="ldap_attr_jobtitle"/>
                        <field name="ldap_attr_jobtitle" nolabel="1" placeholder="title"/>
                        <label for="group_attribute"/>
                        <field name="group_attribute" nolabel="1" placeholder="memberOf"/>
                    </group>
                </group>

                <!-- ========================================== -->
                <!-- GROUPS 섹션                                -->
                <!-- ========================================== -->
                <separator string="GROUPS"/>

                <group col="1">
                    <label for="groups_dn"/>
                    <field name="groups_dn" nolabel="1" placeholder="OU=Groups,DC=company,DC=com"/>
                    <label for="group_filter"/>
                    <field name="group_filter" nolabel="1" placeholder="(objectClass=group)"/>
                    <field name="sync_groups"/>
                    <field name="create_role_per_group" invisible="not sync_groups"/>
                </group>

                <!-- ========================================== -->
                <!-- SYNC STATUS 섹션                          -->
                <!-- ========================================== -->
                <separator string="SYNC STATUS"/>

                <group col="2">
                    <group>
                        <field name="last_sync_date" readonly="1"/>
                        <field name="last_sync_status" readonly="1"/>
                    </group>
                    <group>
                        <field name="last_sync_user_count" readonly="1"/>
                    </group>
                </group>

            </xpath>
        </field>
    </record>

    <!-- LDAP 서버 목록 뷰 확장 -->
    <record id="view_ldap_installer_tree_inherit" model="ir.ui.view">
        <field name="name">res.company.ldap.tree.inherit.polyon</field>
        <field name="model">res.company.ldap</field>
        <field name="inherit_id" ref="auth_ldap.res_company_ldap_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ldap_server']" position="after">
                <field name="sync_groups" string="Sync Groups"/>
            </xpath>
        </field>
    </record>

</odoo>

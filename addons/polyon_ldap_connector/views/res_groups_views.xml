<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- AD 그룹 트리 뷰 -->
    <record id="view_ad_groups_tree" model="ir.ui.view">
        <field name="name">res.groups.tree.ad</field>
        <field name="model">res.groups</field>
        <field name="arch" type="xml">
            <list string="AD Groups">
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="comment"/>
            </list>
        </field>
    </record>

    <!-- AD 그룹 폼 뷰 -->
    <record id="view_ad_groups_form" model="ir.ui.view">
        <field name="name">res.groups.form.ad</field>
        <field name="model">res.groups</field>
        <field name="arch" type="xml">
            <form string="AD Group">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Group Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="full_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Users" name="users">
                            <field name="user_ids" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="login"/>
                                    <field name="email"/>
                                </list>
                            </field>
                        </page>
                        <page string="Access Rights" name="access_rights">
                            <group string="Model Access">
                                <field name="model_access" nolabel="1" colspan="2">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="model_id"/>
                                        <field name="perm_read"/>
                                        <field name="perm_write"/>
                                        <field name="perm_create"/>
                                        <field name="perm_unlink"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Record Rules" name="record_rules">
                            <field name="rule_groups" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="model_id"/>
                                    <field name="domain_force"/>
                                    <field name="perm_read"/>
                                    <field name="perm_write"/>
                                    <field name="perm_create"/>
                                    <field name="perm_unlink"/>
                                </list>
                            </field>
                        </page>
                        <page string="Menus" name="menus">
                            <field name="menu_access" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="complete_name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Views" name="views">
                            <field name="view_access" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="model"/>
                                    <field name="type"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="comment" placeholder="Group description..." nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- AD 그룹 액션 -->
    <record id="action_ad_groups" model="ir.actions.act_window">
        <field name="name">AD Groups</field>
        <field name="res_model">res.groups</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('comment', 'ilike', '[AD Group]')]</field>
        <field name="context">{'default_comment': '[AD Group] '}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_ad_groups_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_ad_groups_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No AD Groups found
            </p>
            <p>
                AD Groups are automatically created when users are synchronized from LDAP.
                Use "Sync All Groups &amp; Users" button in LDAP settings to import users and groups.
            </p>
        </field>
    </record>

    <!-- LDAP 메뉴 (설정 하위) -->
    <menuitem id="menu_ldap_root"
              name="LDAP"
              parent="base.menu_users"
              sequence="30"/>

    <!-- AD 그룹 메뉴 -->
    <menuitem id="menu_ad_groups"
              name="AD Groups"
              parent="menu_ldap_root"
              action="action_ad_groups"
              sequence="10"/>

    <!-- LDAP 서버 메뉴 (기존 액션 재사용) -->
    <menuitem id="menu_ldap_servers"
              name="LDAP Servers"
              parent="menu_ldap_root"
              action="auth_ldap.action_ldap_installer"
              sequence="20"/>

</odoo>

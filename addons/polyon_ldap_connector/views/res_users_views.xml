<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- AD 사용자 트리 뷰 -->
    <record id="view_ad_users_tree" model="ir.ui.view">
        <field name="name">res.users.tree.ad</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="AD Users">
                <field name="name"/>
                <field name="login"/>
                <field name="email"/>
                <field name="ldap_id"/>
                <field name="ad_group_ids" widget="many2many_tags"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- AD 사용자 폼 뷰 -->
    <record id="view_ad_users_form" model="ir.ui.view">
        <field name="name">res.users.form.ad</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="AD User">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'avatar_128'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="User Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="User Info">
                            <field name="login" readonly="1"/>
                            <field name="email"/>
                            <field name="active"/>
                        </group>
                        <group string="LDAP Info">
                            <field name="ldap_id" readonly="1"/>
                            <field name="ldap_dn" readonly="1"/>
                            <field name="is_ldap_user" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="AD Groups" name="ad_groups">
                            <group string="Synchronized AD Groups">
                                <field name="ad_group_ids" widget="many2many_tags" nolabel="1" readonly="1" colspan="2"/>
                            </group>
                            <field name="ad_group_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="full_name"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                        <page string="All Groups" name="all_groups">
                            <field name="group_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="full_name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- AD 사용자 액션 -->
    <record id="action_ad_users" model="ir.actions.act_window">
        <field name="name">AD Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_ldap_user', '=', True)]</field>
        <field name="context">{'active_test': False}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_ad_users_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_ad_users_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No AD Users found
            </p>
            <p>
                AD Users are automatically created when synchronized from LDAP.
                Use "Sync All Groups &amp; Users" button in LDAP settings to import users.
            </p>
        </field>
    </record>

    <!-- AD 사용자 메뉴 -->
    <menuitem id="menu_ad_users"
              name="AD Users"
              parent="polyon_ldap_connector.menu_ldap_root"
              action="action_ad_users"
              sequence="5"/>

    <!-- 사용자 폼 뷰 확장 - AD 역할 표시 -->
    <record id="view_users_form_ad_groups" model="ir.ui.view">
        <field name="name">res.users.form.ad.groups</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- 액세스 권한 탭에 AD Groups 섹션 추가 (Roles 그룹 뒤에) -->
            <xpath expr="//page[@name='access_rights']/group[1]" position="after">
                <group string="AD Groups" invisible="not ad_group_ids">
                    <field name="ad_group_ids" widget="many2many_tags" nolabel="1" readonly="1" colspan="2"/>
                </group>
                <group string="LDAP Info" invisible="not ldap_id">
                    <field name="ldap_id" readonly="1"/>
                    <field name="ldap_dn" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>

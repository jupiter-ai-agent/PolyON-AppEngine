<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ldap_sync_wizard_form" model="ir.ui.view">
        <field name="name">ldap.sync.wizard.form</field>
        <field name="model">ldap.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Sync LDAP Users &amp; Groups">
                <header>
                    <button name="action_refresh_from_ldap" string="Refresh from LDAP"
                            type="object" class="btn-secondary"
                            icon="fa-refresh"
                            confirm="Refresh user/group data from LDAP? Existing policies will be preserved."/>
                    <button name="action_sync_selected" string="Sync Now"
                            type="object" class="btn-primary"
                            icon="fa-play"
                            confirm="Apply sync with strong binding policy? Non-target users will be archived."/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h2>Sync LDAP Users &amp; Groups</h2>
                        <field name="ldap_server_name" readonly="1" nolabel="1"
                               class="text-muted"/>
                    </div>

                    <notebook>
                        <!-- 1. Groups Tab -->
                        <page string="1. Groups" name="groups_tab">
                            <div class="alert alert-info p-2 mb-3" style="font-size: 0.85em;">
                                <i class="fa fa-info-circle me-1"/>
                                동기화할 AD 그룹을 선택하세요. 선택된 그룹의 멤버인 사용자가 자동으로 동기화 대상이 됩니다.
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <span class="badge bg-primary me-3 fs-6">
                                    <field name="selected_group_count" readonly="1" nolabel="1" class="d-inline"/>
                                    /
                                    <field name="group_count" readonly="1" nolabel="1" class="d-inline"/>
                                    selected
                                </span>
                                <button name="action_select_all_groups" string="Select All"
                                        type="object" class="btn-sm btn-secondary me-1"/>
                                <button name="action_deselect_all_groups" string="Deselect All"
                                        type="object" class="btn-sm btn-secondary"/>
                            </div>
                            <field name="group_line_ids" nolabel="1">
                                <list editable="bottom" no_open="1" create="0" delete="0"
                                      decoration-muted="not selected">
                                    <field name="selected" widget="boolean_toggle"/>
                                    <field name="sequence" readonly="1"/>
                                    <field name="name" readonly="1"/>
                                    <field name="description" readonly="1"/>
                                    <field name="member_count" readonly="1"/>
                                    <field name="exists_in_odoo" widget="boolean" string="In Odoo" readonly="1"/>
                                    <field name="ldap_dn" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- 2. Users Tab -->
                        <page string="2. Users" name="users_tab">
                            <div class="alert alert-info p-2 mb-3" style="font-size: 0.85em;">
                                <i class="fa fa-info-circle me-1"/>
                                <b>Group Policy</b> = 선택된 그룹 멤버이면 자동 동기화 |
                                <b>Include</b> = 그룹과 무관하게 항상 동기화 |
                                <b>Exclude</b> = 항상 제외 (아카이브)
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <span class="badge bg-success me-3 fs-6">
                                    <field name="sync_user_count" readonly="1" nolabel="1" class="d-inline"/>
                                    /
                                    <field name="user_count" readonly="1" nolabel="1" class="d-inline"/>
                                    will sync
                                </span>
                                <button name="action_set_all_users_group" string="All Group Policy"
                                        type="object" class="btn-sm btn-secondary me-1"/>
                                <button name="action_set_all_users_enable" string="All Include"
                                        type="object" class="btn-sm btn-secondary me-1"/>
                                <button name="action_set_all_users_disable" string="All Exclude"
                                        type="object" class="btn-sm btn-outline-secondary"/>
                            </div>
                            <field name="user_line_ids" nolabel="1">
                                <list editable="bottom" no_open="1" create="0" delete="0"
                                      decoration-success="is_sync_target"
                                      decoration-muted="not is_sync_target">
                                    <field name="sync_mode" string="Policy"/>
                                    <field name="is_sync_target" string="Sync" widget="boolean" readonly="1"/>
                                    <field name="screen_name" readonly="1"/>
                                    <field name="email" readonly="1"/>
                                    <field name="first_name" readonly="1"/>
                                    <field name="last_name" readonly="1"/>
                                    <field name="job_title" readonly="1"/>
                                    <field name="group_count" string="Groups" readonly="1"/>
                                    <field name="exists_in_odoo" widget="boolean" string="In Odoo" readonly="1"/>
                                    <field name="ldap_dn" column_invisible="1"/>
                                    <field name="ldap_entry_data" column_invisible="1"/>
                                    <field name="member_group_dns" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- 3. Schedule Tab -->
                        <page string="3. Schedule" name="schedule_tab">
                            <group col="2">
                                <group string="Scheduled Sync">
                                    <field name="sync_enabled"/>
                                    <field name="sync_interval" invisible="not sync_enabled"
                                           string="Interval (minutes)"/>
                                </group>
                                <group string="Last Sync Status">
                                    <field name="last_sync_date" readonly="1"/>
                                    <field name="last_sync_user_count" readonly="1"/>
                                    <field name="last_sync_status" readonly="1"/>
                                </group>
                            </group>
                            <div class="alert alert-secondary p-2 mt-3" style="font-size: 0.85em;">
                                <i class="fa fa-clock-o me-1"/>
                                스케줄 동기화 활성화 시, cron이 주기적으로 LDAP 데이터를 갱신하고
                                강력한 바인딩 정책을 자동 적용합니다.
                                위자드에서 설정한 사용자/그룹 정책이 그대로 유지됩니다.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>

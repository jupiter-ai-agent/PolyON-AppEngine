<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="polyon_login" inherit_id="web.login" priority="99">
        <!-- Odoo 19: 로그인 폼 전체를 OIDC 전용으로 교체 -->
        <!-- 이메일/로그인 필드 제거 -->
        <xpath expr="//div[hasclass('field-login')]" position="replace">
            <div class="text-center mb-3">
                <h4>PolyON 계정으로 로그인</h4>
                <p class="text-muted small">PolyON 계정으로 자동 연결됩니다.</p>
            </div>
        </xpath>
        <!-- 비밀번호 input 제거 (Odoo 19: input[@name='password'] 기준) -->
        <xpath expr="//input[@name='password']" position="replace"/>
        <!-- 비밀번호 label 제거 -->
        <xpath expr="//label[@for='password']" position="replace"/>
        <!-- 비밀번호 표시 버튼 제거 -->
        <xpath expr="//button[hasclass('o_show_password')]" position="replace"/>
        <!-- 기본 제출 버튼 제거 -->
        <xpath expr="//button[@type='submit']" position="replace"/>
    </template>
</odoo>

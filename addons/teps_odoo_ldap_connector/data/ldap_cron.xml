<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- LDAP User Import Cron Job -->
        <record id="ir_cron_ldap_user_import" model="ir.cron">
            <field name="name">LDAP: Sync Users &amp; Groups</field>
            <field name="model_id" ref="auth_ldap.model_res_company_ldap"/>
            <field name="state">code</field>
            <field name="code">model._cron_import_ldap_users()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
